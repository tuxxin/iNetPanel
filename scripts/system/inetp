#!/bin/bash
# ==============================================================================
# inetp — Server Account Manager
# Usage: inetp <command>
# ==============================================================================
SCRIPTS_DIR="/root/scripts"
BOLD='\033[1m'; GREEN='\033[1;32m'; CYAN='\033[1;36m'; DIM='\033[2m'; NC='\033[0m'
PANEL_DIR="/var/www/inetpanel"

COMMAND="$1"; shift

case "$COMMAND" in
    -v|--version|version)
        # Panel version
        PANEL_VER=$(php -r "require '${PANEL_DIR}/TiCore/Version.php'; echo Version::get();" 2>/dev/null || echo "unknown")
        echo -e "${BOLD}inetp${NC} v${PANEL_VER}"
        echo ""

        # OS
        if [ -f /etc/os-release ]; then
            OS_NAME=$(. /etc/os-release && echo "$PRETTY_NAME")
        else
            OS_NAME=$(uname -sr)
        fi
        echo -e "  ${GREEN}OS${NC}            $OS_NAME"
        echo -e "  ${GREEN}Kernel${NC}        $(uname -r)"

        # Apache
        APACHE_VER=$(apache2 -v 2>/dev/null | head -1 | grep -oP 'Apache/\K\S+' || echo "not installed")
        echo -e "  ${GREEN}Apache${NC}        $APACHE_VER"

        # lighttpd
        LIGHTY_VER=$(lighttpd -v 2>/dev/null | grep -oP 'lighttpd/\K\S+' || echo "not installed")
        echo -e "  ${GREEN}lighttpd${NC}      $LIGHTY_VER"

        # PHP versions
        PHP_VERS=""
        for fpm in /usr/sbin/php-fpm*; do
            [ -f "$fpm" ] || continue
            v=$(echo "$fpm" | grep -oP '[0-9]+\.[0-9]+')
            [ -n "$v" ] && PHP_VERS="${PHP_VERS} ${v}"
        done
        PHP_DEFAULT=$(php -r "echo PHP_VERSION;" 2>/dev/null || echo "unknown")
        echo -e "  ${GREEN}PHP (CLI)${NC}     $PHP_DEFAULT"
        echo -e "  ${GREEN}PHP-FPM${NC}      ${PHP_VERS:- none}"

        # MariaDB / MySQL
        DB_VER=$(mysql --version 2>/dev/null | grep -oP '[\d]+\.[\d]+\.[\d]+' | head -1 || echo "not installed")
        echo -e "  ${GREEN}MariaDB${NC}       $DB_VER"

        # Certbot
        CB_VER=$(certbot --version 2>/dev/null | grep -oP '[\d]+\.[\d]+\.[\d]+' || echo "not installed")
        echo -e "  ${GREEN}Certbot${NC}       $CB_VER"

        # WireGuard
        if command -v wg &>/dev/null; then
            WG_STATUS="installed"
            [ -f /etc/wireguard/wg0.conf ] && WG_STATUS="configured"
            systemctl is-active wg-quick@wg0 &>/dev/null && WG_STATUS="active"
        else
            WG_STATUS="not installed"
        fi
        echo -e "  ${GREEN}WireGuard${NC}     $WG_STATUS"

        # cloudflared
        CF_VER=$(cloudflared --version 2>/dev/null | grep -oP '[\d]+\.[\d]+\.[\d]+' || echo "not installed")
        echo -e "  ${GREEN}cloudflared${NC}   $CF_VER"

        # Firewall
        FW_STATUS="not installed"
        if command -v firewall-cmd &>/dev/null; then
            FW_STATUS=$(firewall-cmd --state 2>/dev/null || echo "inactive")
        fi
        echo -e "  ${GREEN}Firewall${NC}      $FW_STATUS"

        # Fail2Ban
        F2B_VER=$(fail2ban-client --version 2>/dev/null | grep -oP '[\d]+\.[\d]+\.[\d]+' || echo "not installed")
        echo -e "  ${GREEN}Fail2Ban${NC}      $F2B_VER"

        # vsftpd
        VSFTPD_VER=$(dpkg -s vsftpd 2>/dev/null | grep -oP 'Version: \K[\d]+\.[\d]+\.[\d]+' || echo "not installed")
        echo -e "  ${GREEN}vsftpd${NC}        $VSFTPD_VER"

        # Disk
        DISK_USAGE=$(df -h / 2>/dev/null | awk 'NR==2{print $3 "/" $2 " (" $5 ")"}')
        echo ""
        echo -e "  ${GREEN}Disk${NC}          $DISK_USAGE"

        # Accounts
        ACCT_COUNT=$(ls /etc/apache2/sites-available/*.conf 2>/dev/null | grep -v -cE '000-default|default-ssl|phpmyadmin')
        echo -e "  ${GREEN}Accounts${NC}      $ACCT_COUNT hosted domain(s)"
        echo ""
        ;;

    create_account)   bash "$SCRIPTS_DIR/create_account.sh"   "$@" ;;
    delete_account)   bash "$SCRIPTS_DIR/delete_account.sh"   "$@" ;;
    create_user)      bash "$SCRIPTS_DIR/create_user.sh"      "$@" ;;
    change_password)  bash "$SCRIPTS_DIR/change_password.sh"  "$@" ;;
    delete_user)      bash "$SCRIPTS_DIR/delete_user.sh"      "$@" ;;
    add_domain)       bash "$SCRIPTS_DIR/add_domain.sh"       "$@" ;;
    remove_domain)    bash "$SCRIPTS_DIR/remove_domain.sh"    "$@" ;;
    suspend_account)  bash "$SCRIPTS_DIR/suspend_account.sh"  "$@" ;;
    optimize_images)  bash "$SCRIPTS_DIR/optimize_images.sh"  "$@" ;;
    backup_accounts)  bash "$SCRIPTS_DIR/backup_accounts.sh"  "$@" ;;
    update)           bash "$SCRIPTS_DIR/inetp-update.sh"     "$@" ;;
    panel_update)     php /var/www/inetpanel/scripts/panel_update.php "$@" ;;
    wireguard_setup)     bash "$SCRIPTS_DIR/wireguard_setup.sh"     "$@" ;;
    wireguard_uninstall) bash "$SCRIPTS_DIR/wireguard_uninstall.sh" "$@" ;;
    wg_peer)             bash "$SCRIPTS_DIR/wg_peer.sh"             "$@" ;;
    firewall)          bash "$SCRIPTS_DIR/firewall_manage.sh"   "$@" ;;
    ssl_manage)        bash "$SCRIPTS_DIR/ssl_manage.sh"       "$@" ;;
    fix_permissions)   bash "$SCRIPTS_DIR/fix_permissions.sh"   "$@" ;;
    panel_ssl)         bash "$SCRIPTS_DIR/panel_ssl.sh"         "$@" ;;
    service_monitor)   bash "$SCRIPTS_DIR/service_monitor.sh"   "$@" ;;
    db_size)           bash "$SCRIPTS_DIR/db_size.sh"           "$@" ;;
    get_account_hash)  bash "$SCRIPTS_DIR/get_account_hash.sh"  "$@" ;;
    verify_account)    python3 "$SCRIPTS_DIR/verify_account_credentials.py" "$@" ;;

    # Server health & diagnostics
    status)            bash "$SCRIPTS_DIR/status.sh"           "$@" ;;
    benchmark)         bash "$SCRIPTS_DIR/benchmark.sh"        "$@" ;;
    speedtest)         bash "$SCRIPTS_DIR/speedtest.sh"        "$@" ;;
    dns_check)         bash "$SCRIPTS_DIR/dns_check.sh"        "$@" ;;
    disk_report)       bash "$SCRIPTS_DIR/disk_report.sh"      "$@" ;;

    # Security
    audit)             bash "$SCRIPTS_DIR/audit.sh"            "$@" ;;
    malware_scan)      bash "$SCRIPTS_DIR/malware_scan.sh"     "$@" ;;

    # Maintenance
    reset_password)    bash "$SCRIPTS_DIR/reset_password.sh"   "$@" ;;
    cleanup)           bash "$SCRIPTS_DIR/cleanup.sh"          "$@" ;;
    rotate_logs)       bash "$SCRIPTS_DIR/rotate_logs.sh"      "$@" ;;
    db_repair)         bash "$SCRIPTS_DIR/db_repair.sh"        "$@" ;;

    list)
        echo -e "${BOLD}Hosted Accounts:${NC}"
        FOUND=0
        LAST_USER=""
        for conf in /etc/apache2/sites-available/*.conf; do
            NAME=$(basename "$conf" .conf)
            [[ "$NAME" == "000-default" || "$NAME" == "phpmyadmin" ]] && continue
            PORT=$(grep '<VirtualHost' "$conf" | grep -oP '(?<=:)\d+')
            DOC=$(grep -oP 'DocumentRoot\s+\K\S+' "$conf" 2>/dev/null)
            STATUS="active"
            [ -L "/etc/apache2/sites-enabled/${NAME}.conf" ] || STATUS="suspended"
            # Detect username from DocumentRoot /home/<user>/<domain>/www
            USER=""
            if echo "$DOC" | grep -qP '^/home/[^/]+/[^/]+/www'; then
                USER=$(echo "$DOC" | cut -d/ -f3)
            fi
            if [ -n "$USER" ] && [ "$USER" != "$LAST_USER" ]; then
                [ "$FOUND" -gt 0 ] && echo ""
                echo -e "  ${BOLD}${USER}${NC}"
                LAST_USER="$USER"
            fi
            if [ -n "$USER" ]; then
                echo -e "    ${GREEN}${NAME}${NC}  →  port ${PORT}  [${STATUS}]"
            else
                echo -e "  ${GREEN}${NAME}${NC}  →  port ${PORT}  [${STATUS}]"
            fi
            FOUND=$((FOUND + 1))
        done
        [ "$FOUND" -eq 0 ] && echo "  No accounts found."
        ;;
    *)
        echo -e "${BOLD}inetp — Server Account Manager${NC}"
        echo ""
        echo "  Usage: inetp <command>"
        echo ""
        echo "  Commands:"
        echo -e "    ${GREEN}create_user${NC}       Create a new hosting user"
        echo -e "    ${GREEN}delete_user${NC}       Delete a hosting user (must have no domains)"
        echo -e "    ${GREEN}add_domain${NC}        Add a domain to an existing user"
        echo -e "    ${GREEN}remove_domain${NC}     Remove a domain from a user"
        echo -e "    ${GREEN}create_account${NC}    Create user + first domain"
        echo -e "    ${GREEN}delete_account${NC}    Delete a user and all their domains"
        echo -e "    ${GREEN}suspend_account${NC}   Suspend or resume an account/user"
        echo -e "    ${GREEN}optimize_images${NC}   Optimize images in a target directory"
        echo -e "    ${GREEN}backup_accounts${NC}   Backup all accounts to /backup"
        echo -e "    ${GREEN}update${NC}            Run system package update"
        echo -e "    ${GREEN}panel_update${NC}      Update iNetPanel from GitHub"
        echo -e "    ${GREEN}wireguard_setup${NC}   Set up WireGuard VPN (full server lockdown)"
        echo -e "    ${GREEN}wireguard_uninstall${NC} Remove WireGuard and restore public access"
        echo -e "    ${GREEN}wg_peer${NC}           Manage WireGuard peers"
        echo -e "    ${GREEN}firewall${NC}          Firewall management (status, flush, ban, unban)"
        echo -e "    ${GREEN}fix_permissions${NC}   Reset file/directory permissions for a user"
        echo -e "    ${GREEN}ssl_manage${NC}        SSL certificate management (issue, revoke, renew, status)"
        echo -e "    ${GREEN}list${NC}              List all active accounts and ports"
        echo ""
        echo -e "  ${BOLD}Server Health & Diagnostics:${NC}"
        echo -e "    ${GREEN}status${NC}            Server health summary (CPU, RAM, disk, services)"
        echo -e "    ${GREEN}benchmark${NC}         Quick server benchmark (disk, network, PHP, MySQL)"
        echo -e "    ${GREEN}speedtest${NC}         Network bandwidth test"
        echo -e "    ${GREEN}dns_check${NC}         DNS, SSL, and connectivity diagnostics for a domain"
        echo -e "    ${GREEN}disk_report${NC}       Disk usage breakdown by user/domain"
        echo ""
        echo -e "  ${BOLD}Security:${NC}"
        echo -e "    ${GREEN}audit${NC}             Security audit (permissions, ports, SSL, SSH, PHP)"
        echo -e "    ${GREEN}malware_scan${NC}      Scan PHP files for backdoors and webshells"
        echo ""
        echo -e "  ${BOLD}Maintenance:${NC}"
        echo -e "    ${GREEN}reset_password${NC}    Reset FTP/SSH/MySQL password for a user"
        echo -e "    ${GREEN}cleanup${NC}           Remove temp files, old logs, orphaned FPM pools"
        echo -e "    ${GREEN}rotate_logs${NC}       Force log rotation for all system and user logs"
        echo -e "    ${GREEN}db_repair${NC}         Check and repair MariaDB tables + SQLite vacuum"
        echo ""
        echo -e "    ${GREEN}-v${NC}                Show version and system info"
        echo ""
        ;;
esac
