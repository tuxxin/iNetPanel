# iNetPanel - .gitignore
# https://github.com/tuxxin/iNetPanel

# -----------------------------------------------
# Environment & Secrets
# -----------------------------------------------
# TiCore/.env is not tracked (version lives in Version.php constant)
/TiCore/.env
TiCore/.env.local
TiCore/.env.production
.env.local
.env.*.local

# -----------------------------------------------
# Database
# -----------------------------------------------
db/*

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/
var/log/

# -----------------------------------------------
# PHP / Composer
# -----------------------------------------------
vendor/
composer.lock

# -----------------------------------------------
# Node / NPM (if ever used for assets)
# -----------------------------------------------
node_modules/
npm-debug.log*
package-lock.json

# -----------------------------------------------
# OS & Editor
# -----------------------------------------------
.claude/
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------
# Backups & Temp
# -----------------------------------------------
*.bak
*.tmp
*.temp
/var/backups/

# -----------------------------------------------
# PHP Cache
# -----------------------------------------------
*.cache
cache/
